{
  "name": "brane-hub",
  "version": "0.1.2",
  "description": "Professional Electron-based control plane for AI CLI agents",
  "author": "Brane Team",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/deepsuthar496/Brane.git"
  },
  "main": "electron/main.js",
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "electron:dev": "concurrently --kill-others \"npm run dev\" \"wait-on http://localhost:3000 && electron .\"",
    "electron:build": "npm run build && cross-env CSC_SKIP=true electron-builder",
    "electron:pack": "cross-env CSC_SKIP=true electron-builder --dir"
  },
  "build": {
    "appId": "com.branehub.desktop",
    "productName": "Brane Hub",
    "compression": "maximum",
    "asar": true,
    "asarUnpack": [
      "**/node_modules/node-pty/**/*"
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "deepsuthar496",
        "repo": "Brane"
      }
    ],
    "npmRebuild": false,
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "electron/**/*",
      ".next/**/*",
      "!**/.next/cache{,/**}",
      "public/**/*",
      "next.config.ts",
      "package.json",
      "skills-lock.json",
      "components.json",
      "DESIGN_SYSTEM.md"
    ],
    "win": {
      "target": "nsis",
      "icon": "public/logo.ico",
      "requestedExecutionLevel": "requireAdministrator",
      "forceCodeSigning": false
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true,
      "uninstallDisplayName": "Brane Hub",
      "runAfterFinish": true,
      "createDesktopShortcut": "always",
      "createStartMenuShortcut": true,
      "shortcutName": "Brane Hub",
      "artifactName": "BraneHub_Setup_${version}.${ext}"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "icon": "public/icon.icns"
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "icon": "public/icon.png"
    }
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "@sentry/electron": "^7.13.0",
    "@types/react-syntax-highlighter": "^15.5.13",
    "dotenv": "^17.4.2",
    "electron-log": "^5.4.3",
    "electron-updater": "^6.8.3",
    "next": "16.2.1",
    "node-pty": "^1.1.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-syntax-highlighter": "^16.1.1",
    "typescript-language-server": "^5.3.0",
    "vscode-jsonrpc": "^8.2.1"
  },
  "devDependencies": {
    "@ai-sdk/anthropic": "^3.0.81",
    "@ai-sdk/cerebras": "^2.0.54",
    "@ai-sdk/google": "^3.0.80",
    "@ai-sdk/groq": "^3.0.39",
    "@ai-sdk/mcp": "^1.0.45",
    "@ai-sdk/openai": "^3.0.67",
    "@ai-sdk/openai-compatible": "^2.0.48",
    "@ai-sdk/react": "^3.0.195",
    "@base-ui/react": "^1.3.0",
    "@iconify/react": "^6.0.2",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@openrouter/ai-sdk-provider": "^2.8.0",
    "@tailwindcss/postcss": "^4",
    "@tailwindcss/typography": "^0.5.19",
    "@types/diff": "^7.0.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-search": "^0.16.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "ai": "^6.0.193",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "concurrently": "^9.2.1",
    "cross-env": "^7.0.3",
    "diff": "^9.0.0",
    "electron": "33.2.1",
    "electron-builder": "^26.8.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "highlight.js": "^11.11.1",
    "lucide-react": "^1.14.0",
    "motion": "^12.38.0",
    "nanoid": "^5.1.9",
    "next-themes": "^0.4.6",
    "react-force-graph-2d": "^1.29.1",
    "react-markdown": "^10.1.0",
    "react-resizable-panels": "^4.11.0",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1",
    "shadcn": "^4.1.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5",
    "use-stick-to-bottom": "^1.1.4",
    "wait-on": "^8.0.3",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  }
}
